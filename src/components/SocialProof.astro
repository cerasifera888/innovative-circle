---
const participants = [
  { name: 'Guess',          role: 'Chief Digital Officer',                        slug: 'guess'        },
  { name: 'Mars',           role: 'Global Digital Commerce & eB2B Director',      slug: 'mars'         },
  { name: 'Baleària',       role: 'E-commerce & Customer Experience Director',     slug: 'balearia'     },
  { name: 'Diageo',         role: 'Global Director, Connected Commerce',           slug: 'Diageo'       },
  { name: 'Decathlon',      role: 'Chief Digital Officer',                         slug: 'Decathlon'    },
  { name: 'Rakuten France', role: 'Executive Vice President of Finance',           slug: 'Rakuten'      },
  { name: 'Schwarz Digits', role: 'Head of Innovation',                            slug: 'SchwarzDigits'},
  { name: 'Unilever',       role: 'Digital Marketing, Media & Commerce Lead',      slug: 'Unilever'     },
];
---

<section id="participants" class="border-b border-hairline bg-coal py-20 md:py-24">
  <p class="px-6 text-center text-sm text-fog">
    Leaders from these companies have already joined the Circle
  </p>

  <div class="carousel-outer mt-12">
    <ul class="carousel-track" aria-label="Member companies">
      {[...participants, ...participants].map((p, i) => (
        <li
          class="carousel-card"
          aria-hidden={i >= participants.length ? 'true' : undefined}
        >
          <div class="logo-wrap">
            <img src={`/logos/${p.slug}.png`} alt={p.name} loading="lazy" />
          </div>
          <span class="role">{p.role}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .carousel-outer {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 12%,
      black 88%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 12%,
      black 88%,
      transparent 100%
    );
  }

  .carousel-track {
    display: flex;
    gap: 1rem;
    width: max-content;
    padding: 0.5rem 0 1.5rem;
    list-style: none;
    margin: 0;
    animation: carousel-scroll 38s linear infinite;
  }

  .carousel-track:hover {
    animation-play-state: paused;
  }

  .carousel-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
    width: 11.5rem;
    flex-shrink: 0;
    background: #ffffff;
    border: 1px solid var(--color-hairline);
    border-radius: 0.875rem;
    padding: 1.5rem 1.25rem 1.25rem;
    text-align: center;
  }

  .logo-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 2.75rem;
  }

  .logo-wrap img {
    max-height: 100%;
    max-width: 100%;
    object-fit: contain;
  }

  .role {
    font-size: 0.6875rem;
    line-height: 1.5;
    color: var(--color-fog);
  }

  @keyframes carousel-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .carousel-outer {
      -webkit-mask-image: none;
      mask-image: none;
    }
    .carousel-track {
      animation: none;
      flex-wrap: wrap;
      width: 100%;
      justify-content: center;
      padding-inline: 1.5rem;
    }
  }
</style>
