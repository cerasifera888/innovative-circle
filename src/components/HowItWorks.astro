---
const steps = [
  {
    n: '01',
    title: 'Apply for a conversation',
    desc: 'Share a few details about your role and goals.',
  },
  {
    n: '02',
    title: 'Fit validation call',
    desc: 'A short personal conversation to ensure strong mutual fit.',
  },
  {
    n: '03',
    title: 'Join the Circle',
    desc: 'Participate in curated sessions, connect directly, and co-create with the right people.',
  },
];
---

<section id="how-it-works" class="border-b border-hairline bg-graphite">
  <div class="mx-auto max-w-6xl px-6 py-24 md:py-32">
    <div class="mx-auto max-w-2xl text-center">
      <p class="mb-5 text-xs uppercase tracking-[0.22em] text-fog">How it works</p>
      <h2 class="text-3xl font-semibold tracking-tight md:text-4xl">A simple, personal process</h2>
      <p class="mt-4 text-sm text-fog">
        Both Tech Solutions and Merchants go through the same personal fit process.
      </p>
    </div>

    <ol class="mt-16 grid gap-px overflow-hidden rounded-2xl border border-hairline bg-hairline md:grid-cols-3">
      {
        steps.map((s) => (
          <li class="bg-graphite p-8">
            <div class="font-mono text-sm text-fog">{s.n}</div>
            <h3 class="mt-4 text-xl font-medium">{s.title}</h3>
            <p class="mt-3 leading-relaxed text-mist/70">{s.desc}</p>
          </li>
        ))
      }
    </ol>
  </div>
</section>
