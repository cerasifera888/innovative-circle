---
interface Props {
  href: string;
  variant?: 'primary' | 'ghost';
  size?: 'md' | 'lg';
  class?: string;
  'data-analytics'?: string;
}

const {
  href,
  variant = 'primary',
  size = 'lg',
  class: extra = '',
  ...rest
} = Astro.props;

const base =
  'group inline-flex items-center justify-center gap-2 rounded-full font-medium tracking-tight transition duration-200 focus-visible:ring-2 focus-visible:ring-mist/70 focus-visible:ring-offset-2 focus-visible:ring-offset-ink';

const variants = {
  primary: 'bg-mist text-ink hover:bg-fog',
  ghost: 'border border-hairline text-mist hover:border-mist/60 hover:bg-mist/10',
};

const sizes = {
  md: 'px-5 py-2.5 text-sm',
  lg: 'px-7 py-3.5 text-base',
};
---

<a href={href} class={`${base} ${variants[variant]} ${sizes[size]} ${extra}`} {...rest}>
  <slot />
</a>
