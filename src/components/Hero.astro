---
import Button from './Button.astro';
---

<section id="top" class="relative overflow-hidden border-b border-hairline">
  <!-- Light-blue wash behind the headline (pure CSS, no external assets) -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <!-- blue wash, fading to white at the bottom to meet the next section -->
    <div
      class="absolute inset-0"
      style="background: linear-gradient(180deg, var(--color-sky-mist) 0%, var(--color-sky-haze) 48%, #ffffff 100%);"
    >
    </div>
  </div>

  <div class="mx-auto max-w-5xl px-6 pb-28 pt-16 text-center md:pb-40 md:pt-24">
    <p
      class="mb-7 inline-flex w-fit items-center rounded-full border border-hairline px-4 py-1.5 text-xs uppercase tracking-[0.22em] text-fog"
    >
      Private Innovation Space
    </p>

    <h1
      class="mx-auto max-w-3xl text-3xl font-semibold leading-[1.15] tracking-tight sm:text-4xl md:text-5xl"
    >
      Collaborate with top retailers
      <br />
      <span class="text-fog">&amp; e-commerce leaders</span>
    </h1>

    <p class="mx-auto mt-8 max-w-2xl text-balance text-lg text-mist/80 md:text-xl">
      We open doors for you to personally connect with them.
    </p>

    <div class="mt-11 flex justify-center">
      <Button href="#book" size="lg"
        ><span class="text-ink transition-colors duration-200 group-hover:text-flamingo-light">Connect</span></Button
      >
    </div>
  </div>
</section>
