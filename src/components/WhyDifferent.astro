---
const items = [
  {
    title: 'Human-first by design',
    desc: 'Personal conversations replace automated outreach.',
    icon: 'people',
  },
  {
    title: 'Curated & selective',
    desc: 'Both sides go through a fit validation process.',
    icon: 'filter',
  },
  {
    title: 'Co-creation focused',
    desc: 'You don’t just listen. You shape solutions together.',
    icon: 'shape',
  },
];
---

<section id="why" class="border-b border-hairline">
  <div class="mx-auto max-w-6xl px-6 py-24 md:py-32">
    <div class="mx-auto max-w-2xl text-center">
      <p class="mb-5 text-xs uppercase tracking-[0.22em] text-fog">Why this is different</p>
      <h2 class="text-balance text-3xl font-semibold leading-tight tracking-tight md:text-4xl lg:text-5xl">
        Not another conference. Not another vendor platform.
      </h2>
    </div>

    <div class="mt-16 grid gap-10 md:grid-cols-3">
      {
        items.map((it) => (
          <div class="text-center md:text-left">
            <div class="mx-auto mb-5 inline-flex h-12 w-12 items-center justify-center rounded-xl border border-hairline md:mx-0">
              <svg
                class="h-6 w-6 text-mist"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                {it.icon === 'people' && (
                  <>
                    <circle cx="9" cy="8" r="3" />
                    <circle cx="17" cy="10" r="2.5" />
                    <path d="M3.5 19a5.5 5.5 0 0 1 11 0M15 19a4.5 4.5 0 0 1 5.5-4.4" />
                  </>
                )}
                {it.icon === 'filter' && (
                  <>
                    <path d="M3 5h18l-7 8v5l-4 2v-7L3 5Z" />
                  </>
                )}
                {it.icon === 'shape' && (
                  <>
                    <path d="M12 3 4 7.5v9L12 21l8-4.5v-9L12 3Z" />
                    <path d="M12 12 4 7.5M12 12l8-4.5M12 12v9" stroke-opacity="0.4" />
                  </>
                )}
              </svg>
            </div>
            <h3 class="text-xl font-medium">{it.title}</h3>
            <p class="mt-2 leading-relaxed text-mist/70">{it.desc}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
